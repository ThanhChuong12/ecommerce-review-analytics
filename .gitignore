# ===================================================
# .gitignore — Multimodal Review Analytics Dashboard
# ===================================================

# --- Secrets & Config ---
.env
*.env.local

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
dist/

# --- Dữ liệu (không commit dữ liệu thô/lớn) ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
scraping_agent/output/*
!scraping_agent/output/.gitkeep

# --- Model weights (file lớn, dùng Git LFS nếu cần) ---
backend_ai/models/*.pt
backend_ai/models/*.pth
backend_ai/models/*.bin
backend_ai/models/*.onnx
!backend_ai/models/.gitkeep

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
