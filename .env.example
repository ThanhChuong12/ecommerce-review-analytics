# ===================================================
# .env.example — Sao chép thành .env và điền API keys
# TUYỆT ĐỐI KHÔNG commit file .env lên GitHub!
# ===================================================

# --- Scraping Agent (LLM Agent cho Shopee, v.v.) ---
GOOGLE_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
BROWSER_USE_API_KEY=your_browseruse_api_key_here   # optional

# --- Browser-Use Agent Settings ---
BROWSER_USE_LOGGING_LEVEL=warning   # debug | info | warning | error
ANONYMIZED_TELEMETRY=false

# --- Backend AI: LLM Integration ---
# (Dùng chung GOOGLE_API_KEY và OPENAI_API_KEY ở trên)

# --- Web App Backend Server ---
PORT=3001
PYTHON_AI_SERVICE_URL=http://localhost:8000
